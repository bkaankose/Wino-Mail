                                        Background="{ThemeResource ListViewItemSelectionIndicatorBrush}"
                                        CornerRadius="4"
                                        Visibility="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=Content.IsSelected, Mode=OneWay}" />

                                    <ContentPresenter
