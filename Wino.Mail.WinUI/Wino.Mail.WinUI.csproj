  <!-- Wino.BackgroundService rides inside this package as the secondary full-trust app
       declared in Package.appxmanifest (Application Id="WinoBackgroundService",
       AppListEntry="none"). Because it ships in the same package it runs with the package
       identity: shared ApplicationData/publisher cache, AUMID activation, and app
       notifications shown in Wino Mail's name. It is deliberately NOT a ProjectReference -
       the UI must not depend on companion code, and its payload is framework-dependent
       (never AOT/self-contained), so the publish output is packed as opaque Content. -->
  <Target Name="IncludeCompanionInPackage" BeforeTargets="AssignTargetPaths" Condition="'$(DesignTimeBuild)' != 'true'">
    <PropertyGroup>
      <WinoCompanionPublishDir>$(MSBuildThisFileDirectory)..\Wino.BackgroundService\bin\$(Platform)\$(Configuration)\net10.0-windows10.0.19041.0\win-$(Platform.ToLowerInvariant())\publish\</WinoCompanionPublishDir>
    </PropertyGroup>
    <MSBuild Projects="..\Wino.BackgroundService\Wino.BackgroundService.csproj"
             Targets="Publish"
             Properties="Configuration=$(Configuration);Platform=$(Platform);SelfContained=false" />
    <ItemGroup>
      <!-- Two subtleties, both load-bearing:
           1. TargetPath is set explicitly because items created inside a target do not
              reliably pass through AssignTargetPaths for the packaging pass.
           2. The metadata uses the QUALIFIED form via an intermediate item: an unqualified
              %(RecursiveDir) inside a target batches over the pre-existing Content items
              and stamps every companion file with someone else's path (APPX1101). -->
      <_WinoCompanionPayload Include="$(WinoCompanionPublishDir)**\*.*" Exclude="$(WinoCompanionPublishDir)**\*.pdb" />
      <Content Include="@(_WinoCompanionPayload)">
        <Link>Wino.BackgroundService\%(_WinoCompanionPayload.RecursiveDir)%(_WinoCompanionPayload.Filename)%(_WinoCompanionPayload.Extension)</Link>
        <TargetPath>Wino.BackgroundService\%(_WinoCompanionPayload.RecursiveDir)%(_WinoCompanionPayload.Filename)%(_WinoCompanionPayload.Extension)</TargetPath>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
    </ItemGroup>
  </Target>
