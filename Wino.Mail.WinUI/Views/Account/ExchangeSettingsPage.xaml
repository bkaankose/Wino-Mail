<?xml version="1.0" encoding="utf-8" ?>
<abstract:ExchangeSettingsPageAbstract
    x:Class="Wino.Views.ExchangeSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:abstract="using:Wino.Views.Abstract"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel
            Width="480"
            Padding="24"
            HorizontalAlignment="Center"
            Spacing="12">

            <TextBlock
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="On-premises Exchange (EWS)" />

            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Connect to an on-premises Exchange mailbox using Exchange Web Services."
                TextWrapping="Wrap" />

            <TextBox
                Header="Display name"
                Text="{x:Bind ViewModel.DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBox
                Header="Email address"
                Text="{x:Bind ViewModel.EmailAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!--  Connection fields appear after Discover — filled from discovery, or for manual entry on fallback.  -->
            <StackPanel
                Spacing="12"
                Visibility="{x:Bind ViewModel.IsDiscovered, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">

                <TextBox
                    Header="EWS URL"
                    PlaceholderText="https://mail.example.com/EWS/Exchange.asmx"
                    Text="{x:Bind ViewModel.EwsUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <ToggleSwitch
                    Header="Modern authentication (OAuth)"
                    IsOn="{x:Bind ViewModel.UseModernAuth, Mode=TwoWay}"
                    OffContent="Use password (NTLM / Basic)"
                    OnContent="Sign in with your organization's identity provider" />

                <PasswordBox
                    Header="Password"
                    Password="{x:Bind ViewModel.Password, Mode=TwoWay}"
                    Visibility="{x:Bind ViewModel.UseModernAuth, Mode=OneWay, Converter={StaticResource ReverseBooleanToVisibilityConverter}}" />

                <Expander
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Header="Advanced settings"
                    Visibility="{x:Bind ViewModel.UseModernAuth, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Spacing="12">
                        <TextBox
                            Header="Authority URL"
                            PlaceholderText="https://adfs.example.com/adfs"
                            Text="{x:Bind ViewModel.OAuthAuthority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox
                            Header="Client ID"
                            Text="{x:Bind ViewModel.OAuthClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox
                            Header="Resource (optional — defaults to the EWS server)"
                            PlaceholderText="https://mail.example.com/"
                            Text="{x:Bind ViewModel.OAuthResource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox
                            Header="Redirect URI (optional — auto-derived from the EWS server, e.g. .../owa/)"
                            PlaceholderText="https://mail.example.com/owa/"
                            Text="{x:Bind ViewModel.OAuthRedirectUri, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Expander>
            </StackPanel>

            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                TextWrapping="Wrap" />

            <TextBlock
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Text="{x:Bind ViewModel.ValidationMessage, Mode=OneWay}"
                TextWrapping="Wrap" />

            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="12">
                <ProgressRing
                    Width="20"
                    Height="20"
                    VerticalAlignment="Center"
                    IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button
                    Command="{x:Bind ViewModel.DiscoverEwsUrlCommand}"
                    Content="Discover"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource ReverseBooleanConverter}}"
                    ToolTipService.ToolTip="Discover the EWS URL and authentication from the email address." />
                <Button
                    Command="{x:Bind ViewModel.SaveCommand}"
                    Content="Save"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource ReverseBooleanConverter}}"
                    Style="{ThemeResource AccentButtonStyle}"
                    Visibility="{x:Bind ViewModel.IsDiscovered, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</abstract:ExchangeSettingsPageAbstract>
