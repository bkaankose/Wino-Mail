                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            FontSize="14"
                            FontWeight="Normal"
                            IsHitTestVisible="False">
                            <FlipView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Style="{StaticResource BodyTextBlockStyle}"
